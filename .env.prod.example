# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_string_here
JWT_REFRESH_SECRET=change_me_another_64_char_random_string_here

# ── Firebase Admin (backend) ──────────────────────────────────
FIREBASE_PROJECT_ID=fitbit-4ac7c
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@fitbit-4ac7c.iam.gserviceaccount.com
# Важно: заменить \n на реальные переносы строк или экранировать
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Firebase Web SDK (frontend, bake into image at build time) ─
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fitbit-4ac7c.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fitbit-4ac7c
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fitbit-4ac7c.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
