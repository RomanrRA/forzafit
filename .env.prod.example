# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_string_here
JWT_REFRESH_SECRET=change_me_another_64_char_random_string_here

# ── Mail (Nodemailer SMTP, backend) ───────────────────────────
# Если SMTP_HOST/USER/PASS не заданы — письма сброса пароля пишутся в лог.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FitLog <no-reply@forzafit.myalfanews.com>"

# ── App URL (для ссылок сброса пароля) ────────────────────────
APP_URL=https://forzafit.myalfanews.com
