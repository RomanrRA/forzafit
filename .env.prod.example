# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_string_here
JWT_REFRESH_SECRET=change_me_another_64_char_random_string_here

# ── Mail (TimeWeb SMTP, backend) ──────────────────────────────
# Если SMTP_HOST/USER/PASS не заданы — письма сброса пароля пишутся в лог.
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=no-reply@forzafit.ru
SMTP_PASS=change_me_mailbox_password
SMTP_FROM="ForzaFit <no-reply@forzafit.ru>"

# ── App URL (для ссылок сброса пароля) ────────────────────────
APP_URL=https://forzafit.ru

# ── OpenRouter (AI plan wizard) ────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-5.4-nano
