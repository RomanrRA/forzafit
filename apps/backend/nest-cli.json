{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc"
      }
    },
    "deleteOutDir": true,
    "assets": [
      {
        "include": "ai/prompts/*.md",
        "watchAssets": true
      },
      {
        "include": "workouts/exercises/*.json",
        "watchAssets": true
      }
    ]
  }
}
